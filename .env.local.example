# Copie este arquivo para .env.local e preencha os valores

# Senha do painel admin (escolha uma senha forte)
ADMIN_PASSWORD=sua_senha_aqui

# Segredo para JWT/NextAuth (gere com: openssl rand -base64 32)
NEXTAUTH_SECRET=seu_segredo_aqui
NEXTAUTH_URL=https://blog.editorasetimoselo.com.br

# Google Analytics (opcional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
